# Next.js + Supabase
# Base project URL only — do NOT append /rest/v1/
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Public site URL — used in emails and shareable gallery links (NOT localhost in production)
NEXT_PUBLIC_APP_URL=https://studio-galleries.com

# Server only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Protects /api/cron/* routes (Vercel Cron sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=random-cron-secret
# Optional — for `npm run supabase:auth-urls` (Dashboard → Account → Access Tokens)
# SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxx
GALLERY_SESSION_SECRET=random-secret-for-gallery-cookies

# Resend
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=Studio Galleries <noreply@yourdomain.com>
# Required in production — also determines who is allowed to log into /manage
FEEDBACK_EMAIL=lea0556769466@gmail.com
ADMIN_NAME=לאה

# Cloudflare R2 — photo files (records stay in Supabase)
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET_NAME=albums
NEXT_PUBLIC_R2_PUBLIC_URL=https://albums.studio-galleries.com
# Optional server-side fallback (same value as NEXT_PUBLIC_R2_PUBLIC_URL)
R2_PUBLIC_URL=https://albums.studio-galleries.com
